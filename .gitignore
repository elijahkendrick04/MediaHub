# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
build/
dist/*.tar.gz
dist/*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Secrets and runtime
.env
.env.*
!.env.example
.secret_key
data/secrets.json
data/discovered/clubs/*.json
data/discovered/swimmers/*.json
data/discovered/meets/*.json
data/discovered/pbs/*.json
data/discovered/search_cache/
data/discovered/discovered_sources.jsonl
!data/discovered/**/.gitkeep
data/cache/
data/verify_variation/
data/log_sentinel/
.cache/

# Runtime artefacts
runs_v4/
uploads_v4/
smoke_v8_output/
*.db
data.db
# SQLite WAL/shared-memory sidecars — transient runtime files written next to a
# data.db whenever it is opened in WAL mode. `*.db` does not match these (they
# don't end in .db), so list them explicitly to keep the tree clean.
*.db-wal
*.db-shm
*.db-journal
src/mediahub/data/
src/mediahub/club_profiles/
data/brand_kits/
data/brand_dna_cache/
data/runs_v4/
data/voices/
data/patterns.jsonl
data/planner_inputs/
data/content_plans/

# Local-dev runtime writes (created when DATA_DIR env var is not set and the
# app or tests run from inside the package tree)
src/mediahub/data/
src/mediahub/discovered/
src/mediahub/club_profiles/
src/mediahub/motion_cache/
src/mediahub/render_cache/
src/mediahub/runs_v4/
src/mediahub/turn_into_packs/
# Phase W runtime writes (same no-DATA_DIR fallback)
src/mediahub/print_exports/
src/mediahub/season_wraps/
src/mediahub/autonomy_audit/
# Phase 1.6 Stage G/J — theme_store falls back to writing here when
# DATA_DIR isn't set. Real deployments + tests always set DATA_DIR.
src/themes/

# Node (legacy frontend tooling)
node_modules/
# Remotion lockfile — environment-specific, regenerated by `make remotion`
src/mediahub/remotion/package-lock.json

# Coverage
.coverage
htmlcov/
data/stub_packs/

# Autonomous tester runtime artefacts (the deduped report itself is tracked,
# but per-run raw logs, screenshots and downloaded test inputs are not)
autotest/screenshots/
autotest/runs/
autotest/cache/
autotest/STOP
autotest/reports/council/*
!autotest/reports/council/.gitkeep

# Generated by scripts/inventory_colors.py (Stage A colour audit) — runtime artifact
data/stage_a_color_inventory.csv

# Runtime compliance/security ledgers must never land in the source tree
# (they belong under DATA_DIR; a test without a DATA_DIR override falls
# back here — the tests now always set one, and this guards the repo).
src/mediahub/compliance/*.jsonl
src/mediahub/compliance/consent/
src/mediahub/security_log/
src/mediahub/users.jsonl

# Ephemeral Claude Code agent worktrees (harness-managed; auto-cleaned).
.claude/worktrees/
