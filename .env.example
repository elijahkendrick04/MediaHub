# MediaHub environment variables — copy to .env and fill in your values.
# All keys are optional; the app degrades gracefully without them.

# --- Server ---
PORT=5000
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string

# --- LLM (Anthropic Claude) — used for AI captions and creative briefs. ---
# Without this key, the app falls back to deterministic templated captions.
ANTHROPIC_API_KEY=sk-ant-...
MEDIAHUB_LLM_MODEL=claude-3-5-sonnet-latest

# --- Background-removal / cutout providers ---
# rembg = local CPU model (default, no key needed).
# replicate = Replicate.com API.
# photoroom = PhotoRoom API.
MEDIAHUB_CUTOUT_PROVIDER=rembg
MEDIAHUB_BG_PROVIDER=rembg

REPLICATE_API_TOKEN=r8_...
MEDIAHUB_REPLICATE_BG_MODEL=cjwbw/rembg

PHOTOROOM_API_KEY=...

# --- Rendering ---
# Device pixel ratio used by graphic_renderer when rasterising HTML→PNG.
MEDIAHUB_RENDER_DPR=2

# --- Optional integrations ---
PPLX_TOOL_BRIDGE_LOCAL_URL=
PPLX_TOOL_BRIDGE_TOKEN=

# --- Valyu (live research / deep-search via agent skills) ---
# Required only if using the Valyu skill for real-time data retrieval.
# Get your key at https://platform.valyu.network/
VALYU_API_KEY=vl-...

# --- Storage paths (override only if running outside the repo). ---
DATA_DIR=./data
SWIM_CONTENT_PROFILES_DIR=./data/discovered/clubs
