# MediaHub — operator environment variables.
#
# Post-rewrite, ALL configuration is operator-controlled at deploy time
# via this env file. The settings page is gone; users never see a key
# or configuration knob. Copy this file to `.env`, fill in the values
# below, and the product is fully turnkey for end users.

# --- Server ---
PORT=5000
FLASK_ENV=production
# Long random string — rotate when you suspect compromise.
SECRET_KEY=change-me-to-a-long-random-string


# --- LLM provider (REQUIRED for AI features) ---
#
# Default and recommended: Google Gemini. Free tier covers the small-
# club business model end-to-end (1,500 requests/day on gemini-2.5-flash).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
MEDIAHUB_GEMINI_MODEL=gemini-2.5-flash

# Optional: Anthropic Claude. Higher quality but paid from $0. Set
# MEDIAHUB_LLM_PROVIDER=anthropic to force-prefer Claude even when
# Gemini is also configured. Without the override, the app uses
# Gemini first and falls back to Claude only when Gemini fails.
# MEDIAHUB_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MEDIAHUB_LLM_MODEL=claude-sonnet-4-6

# Without either key, AI features surface "AI unavailable — contact
# your administrator" instead of inventing fake output.


# --- Buffer (OPTIONAL — single-tenant fallback only) ---
#
# Multi-tenant model: each club connects their OWN Buffer account
# via the inline "Connect Buffer" form that appears inside the
# schedule modal the first time they try to schedule. Their token
# is saved on their ClubProfile, not in env. This is the only
# Buffer-TOS-safe pattern for serving multiple clubs from one
# deployment.
#
# The env var below is read ONLY as a fallback when the active
# club's profile has no token — useful for single-tenant
# self-hosted setups where operator IS the customer (one club
# running their own MediaHub instance). Leave it unset for
# multi-tenant deployments.
#
# Clubs that don't have Buffer at all can use the Download button
# inside the schedule modal to grab a caption + visual ZIP and
# post manually. No Buffer / third-party scheduler required.
# BUFFER_ACCESS_TOKEN=...


# --- Background-removal / cutout (optional) ---
# Default `server` runs rembg in-process on the deployed server's CPU
# (free, no per-image API spend). Override with `replicate` or
# `photoroom` plus the matching API key for paid higher-quality cutouts.
# The legacy values `local` and `rembg` are accepted aliases for
# `server` for backward compatibility with older deployment configs.
MEDIAHUB_CUTOUT_PROVIDER=server
# REPLICATE_API_TOKEN=r8_...
# Default Replicate model is 851-labs/background-remover; override only
# if you need a specific model. Different models may expect different
# input schemas — verify before changing.
# MEDIAHUB_REPLICATE_BG_MODEL=851-labs/background-remover
# PHOTOROOM_API_KEY=...


# --- Rendering ---
# Device pixel ratio used by graphic_renderer when rasterising HTML→PNG.
MEDIAHUB_RENDER_DPR=2

# Pins where Playwright looks for Chromium on the deployed server. The
# Dockerfile pre-installs Chromium under /ms-playwright. Set this to
# match the install location used by the deploy image if it differs.
# Unset means Playwright uses ~/.cache/ms-playwright (its default).
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Switch off the Replicate-backed AI background and use the procedural
# water+noise SVG instead. Set to "1" when the operator wants
# deterministic non-AI backgrounds, or to suspend Replicate spend.
# The procedural background is a primary visual element, not a
# heuristic stand-in.
# MEDIAHUB_DISABLE_AI_BG=0

# Toggle @font-face premium font declarations in rendered HTML. "0"
# falls back to system fonts only — useful when running in a font-less
# container.
# MEDIAHUB_RENDER_PREMIUM_FONTS=1

# Toggle the film-grain SVG overlay on rendered cards. "0" removes the
# overlay (slightly faster, marginally crisper).
# MEDIAHUB_RENDER_GRAIN=1

# Render multiple aspect-ratio variants concurrently with separate
# Chromium contexts. "0" forces serial rendering (less RAM, longer).
# MEDIAHUB_RENDER_PARALLEL=1

# Max concurrent Chromium contexts when parallel rendering is on.
# Each context holds ~150 MB; default 3 is safe for a 1 GB worker.
# MEDIAHUB_RENDER_WORKERS=3


# --- Storage paths (override only if running outside the repo) ---
DATA_DIR=./data
SWIM_CONTENT_PROFILES_DIR=./data/discovered/clubs
