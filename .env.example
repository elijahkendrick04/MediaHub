# MediaHub — operator environment variables.
#
# Post-rewrite, ALL configuration is operator-controlled at deploy time
# via this env file. The settings page is gone; users never see a key
# or configuration knob. Copy this file to `.env`, fill in the values
# below, and the product is fully turnkey for end users.

# --- Server ---
PORT=5000
FLASK_ENV=production
# Long random string — rotate when you suspect compromise.
SECRET_KEY=change-me-to-a-long-random-string


# --- LLM provider (REQUIRED for AI features) ---
#
# Default and recommended: Google Gemini. Free tier covers the small-
# club business model end-to-end (1,500 requests/day on gemini-2.5-flash).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
MEDIAHUB_GEMINI_MODEL=gemini-2.5-flash

# Optional: Anthropic Claude. Higher quality but paid from $0. Set
# MEDIAHUB_LLM_PROVIDER=anthropic to force-prefer Claude even when
# Gemini is also configured. Without the override, the app uses
# Gemini first and falls back to Claude only when Gemini fails.
# MEDIAHUB_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MEDIAHUB_LLM_MODEL=claude-sonnet-4-6

# Without either key, AI features surface "AI unavailable — contact
# your administrator" instead of inventing fake output.

# Optional: any OpenAI-compatible endpoint(s). Lets MediaHub use a server
# that speaks the OpenAI /v1/chat/completions schema — Groq, OpenRouter,
# Together, Fireworks, or a self-hosted vLLM / Ollama / llama.cpp box — as
# an additional provider. Unset => this provider is inert and the app
# behaves exactly as Gemini/Anthropic-only.
#
# Comma-separate multiple endpoints for failover (tried in order). Each
# base URL should end in /v1.
# MEDIAHUB_LLM_ENDPOINTS=https://api.groq.com/openai/v1,https://openrouter.ai/api/v1
#
# Bearer token. Optional — keyless local servers (Ollama / llama.cpp) need
# none. Never hard-code; read from env only.
# MEDIAHUB_LLM_API_KEY=sk-...
#
# Model names. Hero surfaces (captions, spotlights, recaps) use the premium
# model; bulk/internal steps use the cheap one. Per-type overrides take the
# form "type=model,type2=model2".
# MEDIAHUB_LLM_MODEL_CHEAP=llama-3.1-8b-instant
# MEDIAHUB_LLM_MODEL_PREMIUM=llama-3.3-70b-versatile
# MEDIAHUB_LLM_MODEL_OVERRIDES=caption=llama-3.3-70b-versatile
#
# Per-request timeout in seconds (default 45).
# MEDIAHUB_LLM_TIMEOUT=45
#
# Force-prefer a provider over the Gemini-first default. Accepts:
# gemini | anthropic | claude (alias for anthropic) | openai. Without it the
# app stays Gemini-first and falls back to the others only when Gemini fails.
# MEDIAHUB_LLM_PROVIDER=openai


# --- Semantic memory / cross-run caption recall (OPTIONAL, Capability 2) ---
#
# Cloud-only embeddings (no local model). Points the memory store at any
# OpenAI-compatible /v1/embeddings endpoint. Unset => the whole feature is
# inert and behaviour is unchanged.
#
# Easiest: reuse your Gemini key via Google's OpenAI-compatibility layer.
# MEDIAHUB_EMBED_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai
# MEDIAHUB_EMBED_MODEL=text-embedding-004
# Key falls back to GEMINI_API_KEY automatically for the Google endpoint;
# set this explicitly for other providers (OpenAI/OpenRouter/Together/…).
# MEDIAHUB_EMBED_API_KEY=
# MEDIAHUB_EMBED_TIMEOUT=45
#
# Vectors are stored in DATA_DIR/memory.db (separate from data.db) via
# sqlite-vec. When no embedding backend is reachable, semantic recall is
# simply unavailable — there is no keyword fallback.
#
# Caption-recall tuning (Capability 2b): a club's stored corpus must reach
# MIN_CORPUS before recall activates (cold-start guard — KNN over a handful of
# captions returns confident noise), and TOPK exemplars are injected per call.
# MEDIAHUB_MEMORY_MIN_CORPUS=50
# MEDIAHUB_MEMORY_TOPK=3


# --- Web research / SearXNG metasearch (OPTIONAL, Capability 3) ---
#
# Research + PB-verification searches run on free DuckDuckGo by default (no key,
# no cost). Optionally point them at a SearXNG metasearch instance for sturdier,
# multi-engine results. MediaHub ships only the HTTP client — it does NOT host
# or bundle SearXNG, so this adds NO running cost unless YOU run a SearXNG
# instance (your own machine, a free-tier box, or an opt-in process inside this
# container). Unset => DuckDuckGo, unchanged.
#
# The SearXNG instance must enable JSON output (search.formats: [html, json]).
# If it's down/misconfigured, MediaHub logs it and falls back to DuckDuckGo.
# SearXNG is AGPL-3.0 — run it STOCK/unmodified; MediaHub only queries it.
# MEDIAHUB_SEARCH_ENDPOINT=http://localhost:8080
# MEDIAHUB_SEARCH_TIMEOUT=10
#
# After a SearXNG failure the client opens a circuit breaker: SearXNG is skipped
# (DuckDuckGo serves) for this many seconds instead of re-probing — and
# re-warning — on every single query. 0 disables the breaker. /healthz/search
# shows the live state and closes the breaker the moment SearXNG answers again.
# MEDIAHUB_SEARCH_BREAKER_COOLDOWN=300
#
# Deep-research loop (Capability 3b) tuning. The loop runs on your EXISTING AI
# provider (Gemini's free tier by default) — no new cost — and is bounded so it
# can't run away. Defaults are conservative; raise only if you need to.
# MEDIAHUB_RESEARCH_MAX_ROUNDS=4     # hard cap on tool-use rounds (1-8)
# MEDIAHUB_RESEARCH_MAX_TOKENS=1200  # per-round output token cap
# Extra authoritative domains for facts / PBs (comma-separated):
# MEDIAHUB_RESEARCH_AUTHORITY_DOMAINS=british-swimming.org
#
# Interactive research console (Capability 3c) — an in-app page that runs the
# bounded loop above on a question you type, in a background thread with a
# polling endpoint (never inline, so it can't block a worker). OFF by default
# because it triggers LLM + network activity; set to 1 to expose it (it's still
# behind sign-in). Same £0 cost path — existing Gemini free tier + search.
# MEDIAHUB_RESEARCH_UI=1
#
# PB-discovery research budget. PB baseline discovery is deterministic and £0 by
# default (web search -> trust-ranked -> deterministically parsed, with an
# identity + authority gate). This is the per-run ceiling on how many times the
# bounded research loop may be spent to PROPOSE extra candidate URLs for a hard-
# to-find athlete (the model never supplies a time — the parser still does). 0
# (default) keeps PB discovery 100% deterministic and adds no cost.
# MEDIAHUB_PB_RESEARCH_LIMIT=0


# --- Scheduler (in-process; Section 6 step 4) ---
#
# A tiny daemon that fires due scheduled tasks (re-ingest, report generation, …)
# in-process — no Celery/Redis, no new infra (£0). It is safe under MediaHub's
# 2 Gunicorn workers because each (task, UTC-slot) is fired via a single atomic
# SQLite claim, so a job runs exactly once. Runs by default; set to 0 to disable.
# MEDIAHUB_SCHEDULER=1
# Tick interval in seconds (how often it checks for due tasks; default 45).
# MEDIAHUB_SCHEDULER_INTERVAL=45
# Catch-up window in seconds: a task whose slot was missed during a brief outage
# is run once if the slot is younger than this; older is stale and skipped
# (default 21600 = 6h).
# MEDIAHUB_SCHEDULER_CATCHUP_SECS=21600


# --- Notifications (OPTIONAL; Section 6 step 4) ---
#
# "Your content pack is ready for review" pings to phone/desktop the moment a
# run finishes. OFF by default (no channel configured => no notifications, no
# cost). Both channels are thin HTTP POSTs over the existing requests dep — no
# daemon bundled, no new infra.
#
# ntfy push (https://ntfy.sh or a self-hosted server). The topic is YOUR secret —
# anyone who knows it can read your notifications — so there is no default; pick
# an unguessable one. Optional bearer token for protected topics.
# MEDIAHUB_NTFY_TOPIC=mediahub-yourclub-7f3a9c
# MEDIAHUB_NTFY_SERVER=https://ntfy.sh
# MEDIAHUB_NTFY_TOKEN=
#
# Generic JSON webhook (Slack / Discord / any endpoint). Receives a structured
# body plus a Slack/Discord-friendly "text" field.
# MEDIAHUB_NOTIFY_WEBHOOK=https://hooks.slack.com/services/...
# MEDIAHUB_NOTIFY_TIMEOUT=8


# --- Log sentinel (OPTIONAL) — production log watchdog with bounded auto-fix ---
#
# Polls this deployment's own Render logs, notifies on known failure patterns
# (via the ntfy/webhook channels above), and — double-opt-in only — applies the
# playbook's safe remediation (v1: a service restart). Inert without BOTH
# Render vars below. Full guide + guardrail model: docs/LOG_SENTINEL.md.
#
# Render API key (dashboard → Account Settings → API Keys) and the srv-… id of
# the service to watch. SECRETS — env/.env only, never committed.
# RENDER_API_KEY=
# RENDER_SERVICE_ID=
# Workspace id; derived from the service automatically when unset.
# RENDER_OWNER_ID=
#
# Master switch for the in-process watchdog thread (default on; it still idles
# unless the Render vars are set). Poll interval in seconds (default 60, min 15).
# MEDIAHUB_SENTINEL=1
# MEDIAHUB_SENTINEL_INTERVAL=60
#
# Auto-fix is OFF by default (notify-only). Enabling is a DOUBLE opt-in:
# the global flag AND one flag per issue id you trust it to handle.
# MEDIAHUB_SENTINEL_AUTOFIX=0
# MEDIAHUB_SENTINEL_AUTOFIX_WORKER_TIMEOUT=0
# MEDIAHUB_SENTINEL_AUTOFIX_OUT_OF_MEMORY=0
#
# Guardrails: instant kill switch for all actions (notifications keep flowing),
# max actions per UTC day, per-issue action cooldown, per-issue notification
# cooldown, and a no-action grace period after boot (anti restart-loop).
# MEDIAHUB_SENTINEL_KILL=0
# MEDIAHUB_SENTINEL_MAX_ACTIONS_PER_DAY=4
# MEDIAHUB_SENTINEL_ACTION_COOLDOWN=21600
# MEDIAHUB_SENTINEL_NOTIFY_COOLDOWN=3600
# MEDIAHUB_SENTINEL_RESTART_GRACE=600
#
# GitHub escalation (optional): every notified finding is also filed as a
# GitHub issue labelled `sentinel` — ONE open issue per problem (closed +
# recurred => a fresh issue). Open sentinel issues are listed automatically in
# docs/ROADMAP.md -> "Production findings", so filed findings land on the
# roadmap; closing the issue clears them. Fine-grained PAT with Issues
# read/write on this one repo. SECRET — env/.env only, never committed.
# MEDIAHUB_SENTINEL_GITHUB_TOKEN=
# MEDIAHUB_SENTINEL_GITHUB_REPO=elijahkendrick04/MediaHub
#
# Public base URL used for the "click to open /healthz" link in notifications.
# MEDIAHUB_PUBLIC_BASE_URL=https://mediahub-gzwc.onrender.com


# --- Autonomy runner (OPTIONAL; Section 6 step 6) ---
#
# A bounded assistant that can prepare content (draft captions, flag cards) on a
# club's behalf and QUEUE it for human review. It NEVER approves, posts, or
# schedules — a person always does that — and exposes only a fixed, narrow set
# of org-scoped tools (no shell/file/web). OFF by default: this is the per-run
# ceiling on tool-use rounds; 0/unset disables the runner entirely. Set e.g. 6
# to enable. £0 (rides the existing AI provider). Pairs with the scheduler: a
# scheduled "autonomy" task can prepare a club's pack for review on a cadence.
# MEDIAHUB_AUTONOMY_MAX_ROUNDS=0


# --- Buffer (OPTIONAL — single-tenant fallback only) ---
#
# Multi-tenant model: each club connects their OWN Buffer account
# via the inline "Connect Buffer" form that appears inside the
# schedule modal the first time they try to schedule. Their token
# is saved on their ClubProfile, not in env. This is the only
# Buffer-TOS-safe pattern for serving multiple clubs from one
# deployment.
#
# The env var below is read ONLY as a fallback when the active
# club's profile has no token — useful for single-tenant
# self-hosted setups where operator IS the customer (one club
# running their own MediaHub instance). Leave it unset for
# multi-tenant deployments.
#
# Clubs that don't have Buffer at all can use the Download button
# inside the schedule modal to grab a caption + visual ZIP and
# post manually. No Buffer / third-party scheduler required.
# BUFFER_ACCESS_TOKEN=...


# --- Autonomous publishing guardrails (Phase 2; all OPTIONAL) ---
#
# Autonomous publishing is opt-in per org per post type (Settings → Autonomy,
# default approval_required) and every post must clear the P2.3 publish gate:
# provenance, confidence threshold, brand safety, safeguarding, rate caps.
#
# Global kill switch — set to 1/true/on/engaged to halt ALL autonomous
# publishing instantly, deployment-wide. Checked first on every gate
# evaluation and again inside the Buffer call. Default: disengaged.
# MEDIAHUB_PUBLISH_KILL_SWITCH=0
#
# Per-org rate caps for the gate's flood protection, counted over the
# posting log. 0 disables that cap. Defaults: 4/hour, 12/day.
# MEDIAHUB_AUTONOMOUS_HOURLY_CAP=4
# MEDIAHUB_AUTONOMOUS_DAILY_CAP=12


# --- Background-removal / cutout (optional) ---
# Default `server` runs rembg in-process on the deployed server's CPU
# (free, no per-image API spend). Override with `replicate` or
# `photoroom` plus the matching API key for paid higher-quality cutouts.
# The legacy values `local` and `rembg` are accepted aliases for
# `server` for backward compatibility with older deployment configs.
# The legacy env var MEDIAHUB_BG_PROVIDER (rembg/replicate) is also still
# read as a fallback; prefer MEDIAHUB_CUTOUT_PROVIDER for new configs.
MEDIAHUB_CUTOUT_PROVIDER=server
# REPLICATE_API_TOKEN=r8_...
# Default Replicate model is 851-labs/background-remover; override only
# if you need a specific model. Different models may expect different
# input schemas — verify before changing.
# MEDIAHUB_REPLICATE_BG_MODEL=851-labs/background-remover
# PHOTOROOM_API_KEY=...


# --- Rendering ---
# Device pixel ratio used by graphic_renderer when rasterising HTML→PNG.
MEDIAHUB_RENDER_DPR=2

# --- Reel / motion engine (P0.1) ---
# Which backend renders the MP4 story cards and meet reels.
#   remotion (default)  Node + Remotion pipeline. NOTE: Remotion is
#                       source-available, NOT free for for-profit orgs of
#                       >3 people (Company License) — see
#                       docs/DEPENDENCY_LICENSING.md.
#   ffmpeg              Free fallback with zero licensing cost: each beat is
#                       the card's own still graphic (Playwright/Chromium)
#                       animated and stitched by FFmpeg (static binary from
#                       the imageio-ffmpeg wheel; system ffmpeg also works).
#                       No Node and no Remotion install needed.
# MEDIAHUB_REEL_ENGINE=remotion
# Explicit FFmpeg binary for the ffmpeg engine (optional; default resolves
# PATH first, then the imageio-ffmpeg bundled static build).
# MEDIAHUB_FFMPEG=/usr/bin/ffmpeg


# Generation Engine v2 — archetype graphics. This is now the DEFAULT engine:
# each card renders as one of the structurally-distinct `layouts/v2/` archetypes
# (autofit, saliency crops, brand role tokens) and, when an LLM provider is
# configured, the Tier B **design-spec director** picks the archetype + emphasis
# + hook FOR THE MOMENT (deterministic seeded picker as the no-LLM floor). Every
# resolved palette is APCA-checked by the brand-compliance gate, so it is legible
# by construction.
#
# Set the KILL-SWITCH below to fall back to the legacy layout engine
# (byte-for-byte as before). Accepts 0 / false / off / no.
# MEDIAHUB_GEN_V2=0

# Pins where Playwright looks for Chromium on the deployed server. The
# Dockerfile pre-installs Chromium under /ms-playwright. Set this to
# match the install location used by the deploy image if it differs.
# Unset means Playwright uses ~/.cache/ms-playwright (its default).
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Generative backgrounds (Tier C) — OPT-IN, default off. Set to "1" to
# composite an Imagen-built brand-aware backdrop UNDER the deterministic
# text layer on v1 layouts. It is a billed API call (uses the Gemini key
# at the top of this file; Imagen needs billing enabled on the Google
# Cloud project — a bare AI Studio free key may 403), so it never spends
# unless the operator switches it on. When off/unavailable the
# procedural water+noise backdrop renders — a primary visual element,
# not a heuristic stand-in. v2 archetypes never fetch it.
# MEDIAHUB_GEN_BG=0

# Legacy kill switch — force-disables the generative background even if
# MEDIAHUB_GEN_BG=1 (kept for back-compat; prefer leaving MEDIAHUB_GEN_BG
# unset instead).
# MEDIAHUB_DISABLE_AI_BG=0

# Imagen model/timeout used when MEDIAHUB_GEN_BG=1.
# MEDIAHUB_IMAGEN_MODEL=imagen-4.0-generate-001
# MEDIAHUB_IMAGEN_TIMEOUT=60

# Toggle @font-face premium font declarations in rendered HTML. "0"
# falls back to system fonts only — useful when running in a font-less
# container.
# MEDIAHUB_RENDER_PREMIUM_FONTS=1

# Toggle the film-grain SVG overlay on rendered cards. "0" removes the
# overlay (slightly faster, marginally crisper).
# MEDIAHUB_RENDER_GRAIN=1

# Render multiple aspect-ratio variants concurrently with separate
# Chromium contexts. "0" forces serial rendering (less RAM, longer).
# MEDIAHUB_RENDER_PARALLEL=1

# Max concurrent Chromium contexts when parallel rendering is on.
# Each context holds ~150 MB; default 3 is safe for a 1 GB worker.
# MEDIAHUB_RENDER_WORKERS=3


# --- Results from a link (paste a results-page URL) ---
# Master kill-switch. "0" hides the input and 404s the route. Default on.
# MEDIAHUB_RESULTS_FETCH_ENABLED=1
# Crawl bounds (a headless-browser crawl is a real cost — these are hard caps):
# MEDIAHUB_RESULTS_FETCH_MAX_PAGES=400
# MEDIAHUB_RESULTS_FETCH_MAX_TOTAL_MB=50
# MEDIAHUB_RESULTS_FETCH_TIMEOUT_S=180
# MEDIAHUB_RESULTS_FETCH_MAX_PAGE_MB=25
# Tier B (rendered browser) budget:
# MEDIAHUB_RESULTS_FETCH_MAX_RENDERS=60
# MEDIAHUB_RESULTS_FETCH_RENDER_BUDGET_S=240
# Tier C (AI page reading) budget:
# MEDIAHUB_RESULTS_FETCH_MAX_AI_READS=12
# See docs/RESULTS_FROM_URL.md for the full model.


# --- Storage paths (override only if running outside the repo) ---
# DATA_DIR is the root; the others derive from it and rarely need overriding.
DATA_DIR=./data
SWIM_CONTENT_PROFILES_DIR=./data/discovered/clubs
# RUNS_DIR=./data/runs_v4          # pipeline run snapshots (default: $DATA_DIR/runs_v4)
# UPLOADS_DIR=./data/uploads_v4    # staged uploads (default: $DATA_DIR/uploads_v4)
# MEDIAHUB_SPORT_PROFILES_DIR=./data/sport_profiles  # sport-profile YAMLs (inert today)


# --- Advanced tuning (all OPTIONAL; sensible defaults ship) ---
#
# These are performance / reliability knobs read directly from the environment.
# You can ignore them for a normal deploy; raise/lower only if you hit a wall.
#
# Rendering concurrency + timeouts (Playwright HTML->PNG):
# MEDIAHUB_MAX_CONCURRENT_RENDERS=1   # parallel render slots (RAM-bound; ~150MB each)
# MEDIAHUB_RENDER_QUEUE_TIMEOUT=180   # secs a render may wait for a free slot
# MEDIAHUB_RENDER_TRY_TIMEOUT=0.75    # secs between slot-acquire retries
#
# Adaptive Theming Engine. On by default; set to 0/false/off/no to disable the
# per-card derived palette and fall back to the static colour cascade.
# MEDIAHUB_ADAPTIVE_THEME=1
#
# Gemini reliability. Per-request timeout, a simple circuit breaker (open after
# N consecutive failures, cool down for S secs), and the "thinking" token budget
# (0 = off; raise for harder reasoning at higher latency/cost).
# MEDIAHUB_GEMINI_TIMEOUT=45
# MEDIAHUB_GEMINI_BREAKER_THRESHOLD=3
# MEDIAHUB_GEMINI_BREAKER_COOLDOWN_S=60
# MEDIAHUB_GEMINI_THINKING_BUDGET=0
#
# PB-discovery + turn-into parallelism (thread-pool fan-out; set PARALLEL=0 to
# force serial, e.g. to respect a strict upstream rate limit).
# MEDIAHUB_PB_DISCOVERY_PARALLEL=1
# MEDIAHUB_PB_DISCOVERY_WORKERS=6
# MEDIAHUB_TURNINTO_PARALLEL=1
# MEDIAHUB_TURNINTO_WORKERS=4
#
# PB-discovery run guards. BUDGET is the wall-clock ceiling (seconds) for the
# whole PB lookup phase of one run — swimmers past it are skipped honestly and
# the run audit carries fetch_budget_exceeded (0 = unlimited). TICK is how
# often a heartbeat progress line is emitted while lookups are in flight, so
# the stale-run watchdog (180s) can tell slow from dead. DDG_CONCURRENCY caps
# simultaneous DuckDuckGo searches across the whole process — bursts above ~2
# from one IP get rate-limited (403/CAPTCHA), which empties every lookup.
# MEDIAHUB_PB_FETCH_BUDGET_S=600
# MEDIAHUB_PB_PROGRESS_TICK_S=45
# MEDIAHUB_SEARCH_DDG_CONCURRENCY=2
#
# Optional edge-tts voiceover for reels (undocumented MS endpoint; opt-in).
# MEDIAHUB_VOICEOVER=1
# MEDIAHUB_VOICEOVER_VOICE=en-GB-RyanNeural
#
# TTS provider slot (P0.4). 'edge' (default) streams from the Microsoft
# endpoint; 'piper' is the registered LOCAL slot — its implementation ships
# with roadmap P5.2 and until then selecting it returns an honest error
# (never a fallback voice).
# MEDIAHUB_TTS_PROVIDER=edge
#
# Sign-in idle timeout (minutes) before a session is considered expired.
# MEDIAHUB_LOGIN_IDLE_MINUTES=30
#
# Retention enforcement (Privacy Notice §8). When set to N > 0, a daily
# scheduler task deletes runs, uploads and generated packs older than N days
# through the full erasure cascade. Unset/0 = keep until manually deleted.
# MEDIAHUB_RETENTION_DAYS=0
#
# Data minimisation toward LLM providers (DPIA mitigation R1). When 1, the
# athlete's name is replaced with a neutral token in caption prompts and
# restored in the returned caption, so Gemini/Anthropic never receive the
# name. Trade-off: first-name/surname address nuance flattens to the full
# name, and brief-prose (content-engine) calls are not covered because the
# name is not separable there. Off by default.
# MEDIAHUB_LLM_PSEUDONYMISE=0


# --- Commercial layer: self-serve auth + Stripe billing (Phase C) ---
#
# OPTIONAL. Leave all of these UNSET and MediaHub runs exactly as before:
# every existing route stays open, account auth is optional, and the
# billing routes honest-error with 503 "billing is not configured for this
# deployment". This is the self-host-safe default — there is no fake or
# stubbed billing path.
#
# Set STRIPE_SECRET_KEY to turn billing on. It is the ONLY place any Stripe
# secret is read; it must come from this env file (never a literal in source).
# Use a test key (sk_test_...) in development, a live key (sk_live_...) in prod.
# STRIPE_SECRET_KEY=sk_test_...
#
# The signing secret for your Stripe webhook endpoint (Dashboard → Developers
# → Webhooks → your /webhooks/stripe endpoint → "Signing secret"). Required to
# verify inbound webhook signatures; an unsigned/forged event is rejected.
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Tier → Stripe Price mapping. These are Stripe *Price IDs*, not amounts —
# MediaHub bakes in NO price number anywhere; the figure shown at checkout is
# whatever the Stripe Price says. Pricing is being validated separately
# (see docs/adr/0011-commercial-reconcile-revenue-reality.md): create the
# Prices in Stripe, paste their IDs here, and change the number in Stripe with
# no code change. A plan whose Price ID is unset simply isn't purchasable.
# STRIPE_PRICE_CLUB=price_...
# STRIPE_PRICE_FEDERATION=price_...
#
# Force the session cookie's Secure flag on/off. Default: on when an HTTPS
# deployment is detected (Render), off for local HTTP dev so the cookie isn't
# dropped. Set to 1 if you terminate TLS in front of MediaHub another way.
# MEDIAHUB_SESSION_COOKIE_SECURE=1


# --- Operator access: developer sign-in (Phase C, OPTIONAL) ---
#
# An env-gated, unrestricted sign-in for YOU, the operator running this
# deployment — full access with no paywall / free-tier limits. It DOES NOT
# EXIST unless MEDIAHUB_DEV_KEY is set: the /developer route 404s and the button
# is hidden, so it is never a public backdoor. Set it to a long random secret,
# visit /developer, enter the key, and you get an unrestricted session. Unset it
# to instantly revoke every operator session. Read from env only — never a
# literal in source, never logged.
# MEDIAHUB_DEV_KEY=change-me-to-a-long-random-secret
#
# Optional label for the operator identity shown in the UI (cosmetic only).
# MEDIAHUB_DEV_EMAIL=developer@mediahub.local


# --- PC.7: public try-before-signup demo (OPTIONAL) ---
#
# The /try surface lets a stranger upload one results file and get a
# watermarked 3-card preview, no account. ON by default; set
# MEDIAHUB_TRY_DEMO=0 to remove the surface entirely (routes 404).
# Demo runs are stamped to the sandboxed "demo-try" org, never web-verify
# PBs, and are swept after 24h by the daily demo_sweep scheduler task.
# MEDIAHUB_TRY_DEMO=1
#
# Daily caps on anonymous demo traffic (counters reset at UTC midnight; a
# counter that fails to persist refuses the demo rather than running
# uncapped).
# MEDIAHUB_TRY_IP_DAILY_CAP=5
# MEDIAHUB_TRY_GLOBAL_DAILY_CAP=40
